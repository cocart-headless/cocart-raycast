{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "cocart-docs",
  "title": "CoCart Docs",
  "description": "Search CoCart API documentation quickly, copy URLs, or open them in your browser.",
  "icon": "extension-icon.png",
  "author": "cocart",
  "categories": [
    "Documentation",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-docs",
      "title": "Search CoCart Docs",
      "description": "Search through CoCart API documentation",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.14.0",
    "@types/react": "19.0.10",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
